:09.542043Z","iopub.execute_input":"2026-04-02T19:54:09.542478Z","iopub.status.idle":"2026-04-02T19:54:12.435979Z","shell.execute_reply.started":"2026-04-02T19:54:09.542452Z","shell.execute_reply":"2026-04-02T19:54:12.435271Z"}},"outputs":[{"name":"stdout","text":"Downloading data from https://storage.googleapis.com/download.tensorflow.org/example_images/flower_photos.tgz\n\u001b[1m228813984/228813984\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m1s\u001b[0m 0us/step\nDataset downloaded to: /root/.keras/datasets/flower_photos\n","output_type":"stream"}],"execution_count":2},{"cell_type":"markdown","source":"## 3. Data Pipeline Preparation\nWe use `image_dataset_from_directory` to create efficient `tf.data.Dataset` objects. We also resize all images to 224x224, which is the standard input size expected by the MobileNetV2 architecture.","metadata":{}},{"cell_type":"code","source":"BATCH_SIZE = 32\nIMG_SIZE = (224, 224)\n\n# Load Training Data\ntrain_ds = tf.keras.utils.image_dataset_from_directory(\n  data_dir,\n  validation_split=0.2,\n  subset=\"training\",\n  seed=123,\n  image_size=IMG_SIZE,\n  batch_size=BATCH_SIZE\n)\n\n# Load Validation Data\nval_ds = tf.keras.utils.image_dataset_from_directory(\n  data_dir,\n  validation_split=0.2,\n  subset=\"validation\",\n  seed=123,\n  image_size=IMG_SIZE,\n  batch_size=BATCH_SIZE\n)\n\nclass_names = train_ds.class_names\nprint(f\"Classes: {class_names}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-02T19:54:12.437030Z","iopub.execute_input":"2026-04-02T19:54:12.437327Z","iopub.status.idle":"2026-04-02T19:54:15.901535Z","shell.execute_reply.started":"2026-04-02T19:54:12.437293Z","shell.execute_reply":"2026-04-02T19:54:15.900933Z"}},"outputs":[{"name":"stdout","text":"Found 3670 files belonging to 1 classes.\nUsing 2936 files for training.\n","output_type":"stream"},{"name":"stderr","text":"I0000 00:00:1775159654.112108      55 gpu_device.cc:2019] Created device /job: